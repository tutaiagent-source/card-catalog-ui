# Copy to .env.local and fill in values

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# Supabase service role key (server-side only)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Stripe
STRIPE_SECRET_KEY="YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="YOUR_STRIPE_WEBHOOK_SECRET"

# Where the customer should land after checkout
NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"

# Stripe price IDs (set these after creating products/prices in Stripe)
STRIPE_COLLECTOR_PRICE_MONTHLY_ID="price_..."
STRIPE_COLLECTOR_PRICE_ANNUAL_ID="price_..."
STRIPE_PRO_PRICE_MONTHLY_ID="price_..."
STRIPE_PRO_PRICE_ANNUAL_ID="price_..."

# Resend (contact form emails)
RESEND_API_KEY="YOUR_RESEND_API_KEY"
# Where emails are sent
RESEND_TO_EMAIL="support@cardcat.io"
# Sender address (must be verified in Resend)
RESEND_FROM_EMAIL="support@cardcat.io"
